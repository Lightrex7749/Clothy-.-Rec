# ClothyRec Backend Configuration
# Copy this file to .env and adjust values

# Path to the folder CONTAINING dataset_clean/
# e.g. C:/Users/HP/.cache/kagglehub/datasets/prashantsharma526/e-commerce-mens-clothing-dataset/versions/2
DATA_ROOT=

# Override model/index dirs (optional – defaults look in ../models and ../clip_index/fashion_reco_index)
# MODELS_DIR=
# INDEX_DIR=

# Upload directory (optional – defaults to backend/static/uploads)
# UPLOAD_DIR=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,*

# Optional: Gemini API keys (server-side only)
# GEMINI_CHAT_API_KEY=
# GEMINI_IMAGE_API_KEY=
# Optional: Gemini text model (defaults to gemini-2.5-flash)
# GEMINI_MODEL=
# Optional: Gemini image model (must be image-capable)
# GEMINI_IMAGE_MODEL=

# Gemini rate limits (requests per minute, per IP)
# GEMINI_CHAT_RPM=60
# GEMINI_IMAGE_RPM=20
# GEMINI_RATE_WINDOW_SEC=60

# YOLO pose model (file name or absolute path)
# YOLO_POSE_MODEL=yolov8s-pose.pt
